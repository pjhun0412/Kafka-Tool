{
  "name": "kafka-tool",
  "version": "0.1.5",
  "description": "A lightweight Electron Kafka desktop tool",
  "author": "Kafka Tool",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on dist/main/main.js http://localhost:5173 && node scripts/start-electron.cjs --dev\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "release:win": "npm run build && electron-builder --win --publish always",
    "start": "node scripts/start-electron.cjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "@vitejs/plugin-react": "^4.3.4",
    "avsc": "^5.7.9",
    "electron-updater": "^6.8.3",
    "kafkajs": "^2.2.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "local.kafka-tool",
    "productName": "Kafka Tool",
    "directories": {
      "output": "out"
    },
    "artifactName": "Kafka-Tool-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "pjhun0412",
        "repo": "Kafka-Tool",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    }
  }
}
